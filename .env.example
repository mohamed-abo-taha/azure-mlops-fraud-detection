# Storage backend for the model registry: "local" (default) or "azure_blob"
STORAGE_BACKEND=local

# Azure Storage connection string. For local testing point this at Azurite:
#   npx azurite --silent
# and use the well-known Azurite dev connection string.
AZURE_STORAGE_CONNECTION_STRING=
MODEL_BLOB_CONTAINER=models
LOCAL_REGISTRY_DIR=artifacts/registry

# Application Insights (optional). When set, scoring telemetry is exported.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Cost model used to choose the decision threshold.
# Missing a fraud (false negative) is much more expensive than a false alarm.
COST_FP=1
COST_FN=50
